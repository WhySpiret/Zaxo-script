       loadstring(game:HttpGet("https://raw.githubusercontent.com/WhySpiret/Zaxo-script/main/ZaxoFly"))()
   end,
})

Tab:CreateToggle({
   Name = "Noclip",
   CurrentValue = false,
   Flag = "Noclip1",
   Callback = function(Value)
    shared.noclip = Value
    local char = game.Players.LocalPlayer.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            if Value then
                humanoid:ChangeState(Enum.HumanoidStateType.Physics)
            else
                humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
        end
    end
end,
})

