   Name = "Troll Script | Admin",
   Icon = 0,
   LoadingTitle = "Загрузка инструментов...",
   LoadingSubtitle = "Версия: Release 1.0",
   ShowText = "Rayfield",
   Theme = "Ocean",
   ToggleUIKeybind = "K",
